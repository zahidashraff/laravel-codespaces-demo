{
    "name": "Laravel Development",
    "image": "mcr.microsoft.com/devcontainers/php:8.3-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "forwardPorts": [8000],
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "esbenp.prettier-vscode"
            ]
        }
    }
}